# Godot generated files
.godot/
/android/
.import/
export.cfg
export_presets.cfg

# Godot imports CSV files as translations by default. The source CSV
# config tables are versioned, but these generated import products are not.
config/tables/*.csv.import
config/tables/*.translation
assets/ui/formal_arcade/**/*.import
output/diagrams/*.import
output/formal_page_options/*.import

